rules_version = '2';

// ============================================================================
// RASCUNHO — revisar e testar antes de fazer deploy!
// Deploy: npx firebase deploy --only firestore:rules --project king-bt-7f559
// Teste antes no console: Firestore > Regras > Playground, ou emulador local.
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function groupData(gid) {
      return get(/databases/$(database)/documents/groups/$(gid)).data;
    }

    function isMember(gid) {
      return signedIn() && request.auth.uid in groupData(gid).members;
    }

    function isGroupAdmin(gid) {
      return signedIn() && request.auth.uid in groupData(gid).admins;
    }

    // Grupo público: qualquer usuário logado pode visitar em modo leitura
    function isPublic(gid) {
      return groupData(gid).visibility == 'publico';
    }

    // Visitante de grupo público solicitando/cancelando inscrição numa
    // competição: só pode mexer no campo joinRequests, nada mais.
    function onlyChangesJoinRequests() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['joinRequests']);
    }

    // ── Usuários ─────────────────────────────────────────────────────────
    match /users/{uid} {
      // Leitura por qualquer autenticado (necessário para telas de membros)
      allow read: if signedIn();
      // Escrita: só o próprio usuário...
      allow write: if signedIn() && request.auth.uid == uid;
      // ...exceto limpar o groupId de outro usuário (fluxo de remoção do
      // grupo pelo admin). Só permite alterar o campo groupId para null.
      allow update: if signedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['groupId'])
        && request.resource.data.groupId == null;
    }

    // ── Grupos ───────────────────────────────────────────────────────────
    match /groups/{gid} {
      // Leitura autenticada: necessária para o join por código
      // (query where('code','==',...)). Membros e admins ficam visíveis.
      allow read: if signedIn();

      // Criação: o criador precisa se colocar como admin e membro
      allow create: if signedIn()
        && request.auth.uid in request.resource.data.admins
        && request.auth.uid in request.resource.data.members;

      // Update: admin do grupo pode tudo; não-admin só pode se adicionar
      // à lista de membros (fluxo de join por código)
      allow update: if isGroupAdmin(gid)
        || (
          signedIn()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members'])
          && request.resource.data.members.hasAll(resource.data.members)
          && request.resource.data.members.removeAll(resource.data.members) == [request.auth.uid]
        );

      allow delete: if isGroupAdmin(gid);

      // ── Subcoleções: membros leem/escrevem; grupo público permite leitura
      // a qualquer usuário logado (modo visitante, somente leitura) ───────
      match /players/{playerId} {
        allow read: if isMember(gid) || (signedIn() && isPublic(gid));
        allow write: if isMember(gid);
      }

      match /competitions/{compId} {
        allow read: if isMember(gid) || (signedIn() && isPublic(gid));
        allow write: if isMember(gid);
        // Visitante de grupo público pode solicitar/cancelar inscrição
        // (Fase 3) sem virar membro — só o campo joinRequests é alterável.
        allow update: if signedIn() && isPublic(gid) && onlyChangesJoinRequests();
      }

      match /feed/{feedId} {
        allow read: if isMember(gid) || (signedIn() && isPublic(gid));
        allow write: if isMember(gid);
      }

      match /analises/{matchId} {
        allow read: if isMember(gid) || (signedIn() && isPublic(gid));
        allow write: if isMember(gid);
      }

      match /treinos/{treinoId} {
        allow read: if isMember(gid) || (signedIn() && isPublic(gid));
        allow write: if isMember(gid);
      }
    }

    // ── Config global (fórmula de pontuação etc.) ────────────────────────
    // Leitura por qualquer autenticado; escrita só pelo Super Admin.
    match /config/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.email == 'joffre.ribeiro@gmail.com';
    }

    // Bloqueia qualquer outro caminho
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
