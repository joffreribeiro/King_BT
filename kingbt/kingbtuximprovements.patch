+              Nenhuma partida registrada ainda.
+            </Text>
+          </Card>
+        )}
+
+        <View style={{ height: Spacing.xl }} />
+      </ScrollView>
+    </SafeAreaView>
+  );
+}
+
+const h2hRow = StyleSheet.create({
